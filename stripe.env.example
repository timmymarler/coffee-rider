# Stripe environment placeholder values
#
# Copy the relevant keys into your local, untracked env files (e.g. `.env.local` for Expo
# and `.env.firebase`/Firebase config for Cloud Functions). Replace all *_PLACEHOLDER values
# with your real keys before running or deploying.

# Merchant ID for Apple Pay (optional override)
STRIPE_MERCHANT_IDENTIFIER=merchant.com.timmy.marler.coffeerider

# Expo publishable keys (safe for client)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_PLACEHOLDER

# Price IDs used in the subscriptions UI
EXPO_PUBLIC_STRIPE_PRICE_MONTHLY=price_test_monthly_PLACEHOLDER
EXPO_PUBLIC_STRIPE_PRICE_ANNUAL=price_test_annual_PLACEHOLDER
EXPO_PUBLIC_STRIPE_PRICE_MONTHLY_LIVE=price_live_monthly_PLACEHOLDER
EXPO_PUBLIC_STRIPE_PRICE_ANNUAL_LIVE=price_live_annual_PLACEHOLDER

# Server-side price IDs (used by Firebase Functions)
STRIPE_TEST_PRICE_MONTHLY=price_test_monthly_PLACEHOLDER
STRIPE_TEST_PRICE_ANNUAL=price_test_annual_PLACEHOLDER
STRIPE_LIVE_PRICE_MONTHLY=price_live_monthly_PLACEHOLDER
STRIPE_LIVE_PRICE_ANNUAL=price_live_annual_PLACEHOLDER

# Server-side secret keys (only for Firebase Functions / backend code)
STRIPE_TEST_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_LIVE_SECRET_KEY=sk_live_PLACEHOLDER

# Webhook signing secrets for verifying Stripe webhook payloads
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_PLACEHOLDER
STRIPE_LIVE_WEBHOOK_SECRET=whsec_live_PLACEHOLDER
